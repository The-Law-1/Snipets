{
	"manifest_version": 3,
	"name": "Snipets",
	"version": "1.0.0",
	"description": "Adds a context menu for selected text and POSTs it to your API.",
	"permissions": ["contextMenus", "storage"],
	"host_permissions": ["https://lsnbxwsivlwbpdxjhyma.supabase.co/functions/v1/*", "https://lsnbxwsivlwbpdxjhyma.supabase.co/*"],
	"background": {
		"service_worker": "dist/background.js"
	},
	"content_scripts": [
		{
			"matches": ["<all_urls>"],
			"js": ["dist/contentScript.js"]
		}
	],
	"options_page": "options.html"
}
